@model LoginformAspCore.Models.UserTable

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: #0d0d0d;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'DM Sans', sans-serif;
        }

        .login-wrapper {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            width: 100%;
            padding: 2rem;
            background:
                radial-gradient(ellipse at 20% 50%, rgba(198, 160, 100, 0.08) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(198, 160, 100, 0.05) 0%, transparent 50%),
                #0d0d0d;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            background: #141414;
            border: 1px solid rgba(198, 160, 100, 0.2);
            border-radius: 2px;
            padding: 3rem 2.5rem;
            position: relative;
            animation: fadeUp 0.6s ease both;
        }

        .login-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 2.5rem;
            right: 2.5rem;
            height: 2px;
            background: linear-gradient(90deg, transparent, #c6a064, transparent);
        }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(24px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .login-eyebrow {
            font-size: 0.65rem;
            font-weight: 500;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: #c6a064;
            margin-bottom: 0.75rem;
        }

        .login-title {
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            font-weight: 600;
            color: #f0ece4;
            margin-bottom: 0.5rem;
            line-height: 1.2;
        }

        .login-subtitle {
            font-size: 0.85rem;
            color: #5a5a5a;
            margin-bottom: 2.5rem;
            font-weight: 300;
        }

        .form-group {
            margin-bottom: 1.5rem;
            position: relative;
        }

        .form-group label {
            display: block;
            font-size: 0.72rem;
            font-weight: 500;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #888;
            margin-bottom: 0.5rem;
        }

        .form-group input.form-control {
            width: 100%;
            background: #0d0d0d;
            border: 1px solid #2a2a2a;
            border-radius: 2px;
            padding: 0.85rem 1rem;
            font-size: 0.9rem;
            font-family: 'DM Sans', sans-serif;
            color: #f0ece4;
            outline: none;
            transition: border-color 0.25s ease, box-shadow 0.25s ease;
        }

        .form-group input.form-control::placeholder {
            color: #3a3a3a;
        }

        .form-group input.form-control:focus {
            border-color: #c6a064;
            box-shadow: 0 0 0 3px rgba(198, 160, 100, 0.08);
        }

        .text-danger {
            font-size: 0.75rem;
            color: #e05c5c !important;
            margin-top: 0.35rem;
            display: block;
        }

        .btn-login {
            width: 100%;
            padding: 0.9rem;
            margin-top: 0.5rem;
            background: #c6a064;
            color: #0d0d0d;
            border: none;
            border-radius: 2px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.78rem;
            font-weight: 500;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            cursor: pointer;
            transition: background 0.2s ease, transform 0.15s ease;
        }

        .btn-login:hover {
            background: #d4af78;
            transform: translateY(-1px);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .error-message {
            margin-top: 1rem;
            padding: 0.75rem 1rem;
            background: rgba(224, 92, 92, 0.08);
            border: 1px solid rgba(224, 92, 92, 0.25);
            border-radius: 2px;
            font-size: 0.8rem;
            color: #e05c5c;
            text-align: center;
        }

        .divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 2rem 0 1.5rem;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #222;
        }

        .divider span {
            font-size: 0.7rem;
            color: #3a3a3a;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .signup-link {
            display: block;
            text-align: center;
            font-size: 0.8rem;
            color: #5a5a5a;
            text-decoration: none;
            transition: color 0.2s ease;
        }

        .signup-link span {
            color: #c6a064;
        }

        .signup-link:hover {
            color: #c6a064;
        }
    </style>
</head>
<body>

<div class="login-wrapper">
    <div class="login-card">

        <p class="login-eyebrow">Welcome back</p>
        <h1 class="login-title">Sign in</h1>
        <p class="login-subtitle">Enter your credentials to continue</p>

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:1rem;"></div>

            <div class="form-group">
                <label asp-for="Email">Email Address</label>
                <input asp-for="Email" class="form-control" placeholder="you@example.com" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-login">Sign In</button>

            @* ✅ Only ONE error message block, removed duplicate *@
            @if (ViewBag.error != null)
            {
                <div class="error-message">@ViewBag.error</div>
            }

            <div class="divider"><span>or</span></div>

            <a asp-controller="Home" asp-action="SignUp" class="signup-link">
                Not registered yet? <span>Create an account</span>
            </a>

        </form>
    </div>
</div>

</body>
</html>