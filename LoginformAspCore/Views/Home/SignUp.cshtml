@model LoginformAspCore.Models.UserTable

@{
    ViewData["Title"] = "SignUp";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>SignUp</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: #0d0d0d;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'DM Sans', sans-serif;
        }

        .signup-wrapper {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            width: 100%;
            padding: 2rem;
            background:
                radial-gradient(ellipse at 20% 50%, rgba(198, 160, 100, 0.08) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(198, 160, 100, 0.05) 0%, transparent 50%),
                #0d0d0d;
        }

        .signup-card {
            width: 100%;
            max-width: 460px;
            background: #141414;
            border: 1px solid rgba(198, 160, 100, 0.2);
            border-radius: 2px;
            padding: 3rem 2.5rem;
            position: relative;
            animation: fadeUp 0.6s ease both;
        }

        .signup-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 2.5rem;
            right: 2.5rem;
            height: 2px;
            background: linear-gradient(90deg, transparent, #c6a064, transparent);
        }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(24px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .signup-eyebrow {
            font-size: 0.65rem;
            font-weight: 500;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: #c6a064;
            margin-bottom: 0.75rem;
        }

        .signup-title {
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            font-weight: 600;
            color: #f0ece4;
            margin-bottom: 0.5rem;
            line-height: 1.2;
        }

        .signup-subtitle {
            font-size: 0.85rem;
            color: #5a5a5a;
            margin-bottom: 2.5rem;
            font-weight: 300;
        }

        /* Two column grid for Name & Gender, Age & Email */
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
            position: relative;
        }

        .form-group label {
            display: block;
            font-size: 0.72rem;
            font-weight: 500;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #888;
            margin-bottom: 0.5rem;
        }

        .form-group input.form-control,
        .form-group select.form-control {
            width: 100%;
            background: #0d0d0d;
            border: 1px solid #2a2a2a;
            border-radius: 2px;
            padding: 0.85rem 1rem;
            font-size: 0.9rem;
            font-family: 'DM Sans', sans-serif;
            color: #f0ece4;
            outline: none;
            transition: border-color 0.25s ease, box-shadow 0.25s ease;
            appearance: none;
        }

        .form-group select.form-control option {
            background: #141414;
            color: #f0ece4;
        }

        .form-group input.form-control::placeholder {
            color: #3a3a3a;
        }

        .form-group input.form-control:focus,
        .form-group select.form-control:focus {
            border-color: #c6a064;
            box-shadow: 0 0 0 3px rgba(198, 160, 100, 0.08);
        }

        .text-danger {
            font-size: 0.75rem;
            color: #e05c5c !important;
            margin-top: 0.35rem;
            display: block;
        }

        .btn-signup {
            width: 100%;
            padding: 0.9rem;
            margin-top: 0.5rem;
            background: #c6a064;
            color: #0d0d0d;
            border: none;
            border-radius: 2px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.78rem;
            font-weight: 500;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            cursor: pointer;
            transition: background 0.2s ease, transform 0.15s ease;
        }

        .btn-signup:hover {
            background: #d4af78;
            transform: translateY(-1px);
        }

        .btn-signup:active {
            transform: translateY(0);
        }

        .divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 2rem 0 1.5rem;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #222;
        }

        .divider span {
            font-size: 0.7rem;
            color: #3a3a3a;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .back-link {
            display: block;
            text-align: center;
            font-size: 0.8rem;
            color: #5a5a5a;
            text-decoration: none;
            transition: color 0.2s ease;
        }

        .back-link span {
            color: #c6a064;
        }

        .back-link:hover {
            color: #c6a064;
        }

        .error-message {
            margin-bottom: 1.5rem;
            padding: 0.75rem 1rem;
            background: rgba(224, 92, 92, 0.08);
            border: 1px solid rgba(224, 92, 92, 0.25);
            border-radius: 2px;
            font-size: 0.8rem;
            color: #e05c5c;
            text-align: center;
        }
    </style>
</head>
<body>

<div class="signup-wrapper">
    <div class="signup-card">

        <p class="signup-eyebrow">Create Account</p>
        <h1 class="signup-title">Sign Up</h1>
        <p class="signup-subtitle">Fill in your details to get started</p>

        <form asp-action="SignUp" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="error-message"></div>

            <!-- Name & Gender Row -->
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Name">Full Name</label>
                    <input asp-for="Name" class="form-control" placeholder="John Doe" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Gender">Gender</label>
                    <select asp-for="Gender" class="form-control">
                        <option value="">Select</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-danger"></span>
                </div>
            </div>

            <!-- Age & Email Row -->
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Age">Age</label>
                    <input asp-for="Age" class="form-control" placeholder="25" type="number" />
                    <span asp-validation-for="Age" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email">Email</label>
                    <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            </div>

            <!-- Password Full Width -->
            <div class="form-group">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-signup">Create Account</button>

            <div class="divider"><span>or</span></div>

            <a asp-controller="Home" asp-action="Login" class="back-link">
                Already have an account? <span>Sign In</span>
            </a>

        </form>
    </div>
</div>

</body>
</html>