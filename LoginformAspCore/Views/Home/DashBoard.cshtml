@{
    ViewData["Title"] = "DashBoard";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>DashBoard</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: #0d0d0d;
            min-height: 100vh;
            font-family: 'DM Sans', sans-serif;
            color: #f0ece4;
        }

        /* ── Navbar ── */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 18px 40px;
            background: #141414;
            border-bottom: 1px solid rgba(198, 160, 100, 0.2);
            position: relative;
        }

        .navbar::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 40px;
            right: 40px;
            height: 1px;
            background: linear-gradient(90deg, transparent, #c6a064, transparent);
        }

        .navbar-brand {
            font-family: 'Playfair Display', serif;
            font-size: 20px;
            font-weight: 600;
            color: #c6a064;
            letter-spacing: 1px;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .user-info span {
            font-size: 0.82rem;
            color: #888;
            letter-spacing: 0.08em;
        }

        .logout-btn {
            background: transparent;
            color: #c6a064;
            padding: 7px 20px;
            border: 1px solid rgba(198, 160, 100, 0.4);
            border-radius: 2px;
            text-decoration: none;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.72rem;
            font-weight: 500;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            transition: all 0.2s ease;
        }

        .logout-btn:hover {
            background: #c6a064;
            color: #0d0d0d;
        }

        /* ── Page Background ── */
        .page-wrapper {
            min-height: calc(100vh - 65px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 3rem 2rem;
            background:
                radial-gradient(ellipse at 20% 50%, rgba(198, 160, 100, 0.08) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(198, 160, 100, 0.05) 0%, transparent 50%),
                #0d0d0d;
        }

        /* ── Welcome Text ── */
        .welcome-eyebrow {
            font-size: 0.65rem;
            font-weight: 500;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: #c6a064;
            margin-bottom: 0.75rem;
            text-align: center;
        }

        .welcome-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.4rem;
            font-weight: 600;
            color: #f0ece4;
            text-align: center;
            margin-bottom: 0.5rem;
        }

        .welcome-title span {
            color: #c6a064;
        }

        .welcome-subtitle {
            font-size: 0.85rem;
            color: #5a5a5a;
            text-align: center;
            margin-bottom: 3rem;
            font-weight: 300;
        }

        /* ── Coming Soon Card ── */
        .coming-soon-card {
            width: 100%;
            max-width: 500px;
            background: #141414;
            border: 1px solid rgba(198, 160, 100, 0.2);
            border-radius: 2px;
            padding: 3rem 2.5rem;
            text-align: center;
            position: relative;
            animation: fadeUp 0.6s ease both;
        }

        .coming-soon-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 2.5rem;
            right: 2.5rem;
            height: 2px;
            background: linear-gradient(90deg, transparent, #c6a064, transparent);
        }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(24px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .coming-soon-label {
            font-size: 0.65rem;
            font-weight: 500;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: #c6a064;
            margin-bottom: 1rem;
        }

        .coming-soon-title {
            font-family: 'Playfair Display', serif;
            font-size: 3rem;
            font-weight: 600;
            color: #f0ece4;
            letter-spacing: 4px;
            margin-bottom: 1rem;
            background: linear-gradient(90deg, #c6a064, #f0ece4, #c6a064);
            background-size: 200%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: shine 4s linear infinite;
        }

        @@keyframes shine {
            0%   { background-position: 0%; }
            100% { background-position: 200%; }
        }

        .coming-soon-text {
            font-size: 0.85rem;
            color: #5a5a5a;
            font-weight: 300;
            letter-spacing: 0.05em;
        }

        /* ── Dots ── */
        .dots {
            display: flex;
            gap: 10px;
            justify-content: center;
            margin-top: 2rem;
        }

        .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #c6a064;
            animation: bounce 1.2s infinite ease-in-out;
        }

        .dot:nth-child(2) {
            animation-delay: 0.2s;
            background: #888;
        }

        .dot:nth-child(3) {
            animation-delay: 0.4s;
            background: #3a3a3a;
        }

        @@keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50%       { transform: translateY(-8px); }
        }

        /* ── Divider ── */
        .divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-top: 2rem;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #222;
        }

        .divider span {
            font-size: 0.7rem;
            color: #3a3a3a;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <div class="navbar">
        <div class="navbar-brand">✦ MyApp</div>
        <div class="user-info">
            <span>👤 @ViewBag.MyUser</span>
            <a asp-controller="Home" asp-action="Logout" class="logout-btn">Logout</a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="page-wrapper">

        <p class="welcome-eyebrow">Dashboard</p>
        <h1 class="welcome-title">Hello, <span>@ViewBag.MyUser</span> 👋</h1>
        <p class="welcome-subtitle">Here's what's happening with your account</p>

        <div class="coming-soon-card">
            <p class="coming-soon-label">Status</p>
            <h2 class="coming-soon-title">COMING SOON</h2>
            <p class="coming-soon-text">We're working on something amazing. Stay tuned!</p>

            <div class="dots">
                <div class="dot"></div>
                <div class="dot"></div>
                <div class="dot"></div>
            </div>

            <div class="divider"><span>secured</span></div>
        </div>

    </div>

</body>
</html>